{
  "name": "vector-control-hub",
  "description": "Local-first dashboard for controlling an Anki / DDL Vector robot with embedded, direct, and legacy compatibility engine modes.",
  "private": true,
  "version": "0.1.27",
  "author": "P4ND4907",
  "main": "desktop/main.mjs",
  "license": "MIT",
  "homepage": "https://github.com/P4ND4907/Vector",
  "repository": {
    "type": "git",
    "url": "https://github.com/P4ND4907/Vector.git"
  },
  "bugs": {
    "url": "https://github.com/P4ND4907/Vector/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "vector",
    "wirepod",
    "robotics",
    "react",
    "local-first"
  ],
  "workspaces": [
    "app",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace app",
    "dev:app": "npm run dev --workspace app",
    "dev:server": "npm run dev --workspace server",
    "start": "powershell -ExecutionPolicy Bypass -File ./Launch-Vector-Control-Hub.ps1",
    "build": "npm run build --workspace app && npm run build --workspace server",
    "preview": "powershell -ExecutionPolicy Bypass -File ./Launch-Vector-Control-Hub.ps1 -NoOpen",
    "typecheck": "npm run typecheck --workspace app && npm run typecheck --workspace server",
    "lint": "npm run typecheck",
    "test": "npm run test --workspace server",
    "test:commands": "npm test --workspace server -- command-engine.test.ts",
    "test:pandora": "node --test ./scripts/pandora-release-gate.test.mjs",
    "test:ui": "npm run test --workspace app",
    "test:coverage": "npm run test --workspace server && npm run test --workspace app",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md}\" --ignore-path .gitignore",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "verify:ci": "npm run typecheck && npm run test:pandora && npm run test:commands && npm run build",
    "verify:release": "npm run typecheck && npm run test && npm run build",
    "verify:play": "node ./scripts/release-health-check.mjs",
    "mobile:android:doctor": "npm run mobile:doctor:android --workspace app",
    "mobile:android:prepare": "npm run mobile:prepare:android --workspace app",
    "mobile:android:open": "npm run mobile:open:android --workspace app",
    "mobile:android:debug": "npm run mobile:debug:android --workspace app",
    "mobile:android:smoke": "node ./scripts/android-emulator-smoke.mjs",
    "mobile:android:release": "node ./scripts/bump-android-version.mjs && npm run mobile:android:prepare && npm run mobile:release:android --workspace app",
    "mobile:android:bundle-release": "node ./scripts/bump-android-version.mjs && npm run mobile:android:prepare && npm run mobile:android:bundle && node ./scripts/stamp-android-release.mjs",
    "mobile:android:bundle": "npm run mobile:bundle:android --workspace app",
    "desktop:assets": "node ./scripts/generate-desktop-icons.mjs",
    "desktop:clean-output": "node ./scripts/clean-electron-output.mjs",
    "desktop:dev": "npm run desktop:assets && npm run build && electron .",
    "desktop:pack": "npm run desktop:clean-output && npm run desktop:assets && npm run build && electron-builder --dir",
    "desktop:dist": "npm run desktop:clean-output && npm run desktop:assets && npm run build && electron-builder --win nsis && electron-builder --win portable",
    "release:windows": "npm run desktop:dist",
    "pandora": "node ./scripts/pandora-release-gate.mjs",
    "cache:scan": "pandora scan --write --force",
    "cache:smart-build": "pandora smart-build",
    "cache:smart-cycle": "pandora smart-cycle",
    "cache:stats": "pandora stats",
    "cache:clean": "pandora clean",
    "cache:learn": "pandora learn",
    "cache:doctor": "pandora doctor",
    "cache:dashboard": "pandora dashboard",
    "cache:watch": "pandora watch --write",
    "cache:oss": "pandora oss-scan",
    "cache:build": "pandora run app",
    "cache:explain": "pandora explain app",
    "cache:run:app": "pandora run app",
    "cache:push:app": "pandora push app",
    "cache:pull:app": "pandora pull app",
    "cache:run:build": "pandora run build",
    "cache:push:build": "pandora push build",
    "cache:pull:build": "pandora pull build",
    "cache:run:server": "pandora run server",
    "cache:push:server": "pandora push server",
    "cache:pull:server": "pandora pull server",
    "cache:run:desktopAssets": "pandora run desktopAssets",
    "cache:push:desktopAssets": "pandora push desktopAssets",
    "cache:pull:desktopAssets": "pandora pull desktopAssets",
    "cache:run:desktop": "pandora run desktop",
    "cache:push:desktop": "pandora push desktop",
    "cache:pull:desktop": "pandora pull desktop",
    "cache:run:android": "pandora run android",
    "cache:push:android": "pandora push android",
    "cache:pull:android": "pandora pull android"
  },
  "devDependencies": {
    "@pandora/build-cache": "file:../pandora-desktop",
    "@resvg/resvg-js": "^2.6.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "prettier": "^3.8.3"
  },
  "build": {
    "appId": "com.vectorcontrolhub.app",
    "productName": "Vector Control Hub",
    "directories": {
      "app": ".",
      "buildResources": "build-resources",
      "output": "dist-electron"
    },
    "files": [
      "desktop/**/*",
      "app/dist/**/*",
      "server/dist/**/*",
      "server/protobufs/**/*",
      "scripts/serve-static-app.mjs",
      "package.json"
    ],
    "extraMetadata": {
      "main": "desktop/main.mjs"
    },
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false,
      "icon": "build-resources/icons/vector-control-hub.ico"
    },
    "nsis": {
      "artifactName": "Vector-Control-Hub-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vector Control Hub"
    },
    "portable": {
      "artifactName": "Vector-Control-Hub-Portable-${version}-${arch}.${ext}"
    }
  }
}
