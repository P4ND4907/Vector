{
  "name": "vector-control-hub-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "npm run build && node ../scripts/serve-static-app.mjs --root dist --host 127.0.0.1 --port 4173",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "mobile:sync": "cap sync android",
    "mobile:prepare:android": "npm run build && cap sync android",
    "mobile:open:android": "cap open android",
    "mobile:doctor:android": "node ../scripts/check-android-env.mjs",
    "mobile:debug:android": "node ../scripts/run-android-gradle.mjs assembleDebug",
    "mobile:release:android": "node ../scripts/run-android-gradle.mjs assembleRelease",
    "mobile:bundle:android": "node ../scripts/run-android-gradle.mjs bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.1",
    "tailwind-merge": "^3.3.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  }
}
