# Copy this file to server/.env.local and fill in your own values.
# Do NOT commit server/.env.local – it is listed in .gitignore.
#
# When running via Docker Compose, these values are set in docker-compose.yml
# (or overridden in a root-level .env file). You do not need a .env.local
# inside the container.

# ── Server ────────────────────────────────────────────────────────────────────

# Port the Express server listens on (default: 8787)
PORT=8787

# Set to "production" when serving real users
NODE_ENV=development

# Path to the JSON data file used for local storage (relative or absolute)
DATA_FILE_PATH=./data/vector-data.json

# ── WirePod ───────────────────────────────────────────────────────────────────

# Base URL of your local WirePod instance
# Docker Compose sets this to http://wirepod:8080 automatically
WIREPOD_BASE_URL=http://127.0.0.1:8080

# Request timeout for WirePod API calls (milliseconds)
WIREPOD_TIMEOUT_MS=4000

# ── OpenAI ────────────────────────────────────────────────────────────────────

# Your OpenAI API key – required for AI command features
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=replace-with-your-rotated-openai-key

# OpenAI model to use for AI command generation
OPENAI_MODEL=gpt-4.1-mini

# ── Support & monetisation ───────────────────────────────────────────────────

SUPPORT_EMAIL=you@example.com

STRIPE_PAYMENT_LINK_PRO=https://buy.stripe.com/replace-pro
STRIPE_PAYMENT_LINK_SETUP=https://buy.stripe.com/replace-setup
STRIPE_PAYMENT_LINK_STUDIO=https://buy.stripe.com/replace-studio
